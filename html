<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TokTube</title>

<style>
body {
  margin:0;
  background:black;
  font-family:sans-serif;
  overflow:hidden;
}
.container {
  height:100vh;
  overflow-y:scroll;
  scroll-snap-type:y mandatory;
}
.video-box {
  height:100vh;
  position:relative;
  scroll-snap-align:start;
}
iframe {
  width:100%;
  height:100%;
  border:none;
}
.overlay {
  position:absolute;
  bottom:80px;
  left:10px;
  color:white;
}

.actions {
  position:absolute;
  right:12px;
  bottom:160px;
  color:white;
  text-align:center;
}
.actions div {
  margin:18px 0;
  cursor:pointer;
  font-size:28px;
  background:rgba(0,0,0,0.5);
  padding:12px;
  border-radius:50%;
  transition:all 0.2s ease;
  box-shadow:0 0 10px rgba(255,255,255,0.2);
}
.actions div:active {
  transform:scale(1.4) rotate(8deg);
  box-shadow:0 0 20px rgba(255,255,255,0.6);
}
.actions div:hover {
  transform:scale(1.15);
  background:rgba(255,255,255,0.2);
}
.actions div::after {
  content: attr(data-label);
  display:block;
  font-size:10px;
  opacity:0.7;
  margin-top:4px;
}

.topbar {
  position:fixed;
  top:0;
  width:100%;
  display:flex;
  overflow-x:auto;
  background:rgba(0,0,0,0.6);
  z-index:10;
}
.topbar button {
  color:white;
  background:none;
  border:none;
  padding:10px;
}
</style>
</head>

<body>

<div class="topbar">
  <button onclick="setCategory('trending')">🔥 Tren</button>
  <button onclick="setCategory('comedy')">😂 Lucu</button>
  <button onclick="setCategory('anime')">🎌 Anime</button>
  <button onclick="setCategory('news')">📰 Berita</button>
  <button onclick="setCategory('sports')">⚽ Sport</button>
  <button onclick="setCategory('product')">🛒 Produk</button>
</div>

<div class="container" id="feed"></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-app.js";

const firebaseConfig = {
