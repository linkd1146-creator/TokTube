initializeApp(firebaseConfig);
</script>

<script>
const API_KEY = "AIzaSyDpN_GFfGfnjlR6irFPhpXmnCznqs4c4Z0";
let nextPageToken = "";
let currentQuery = "trending shorts";

const productLinks = [
"https://collshp.com/l0ver5",
"https://s.blibli.com/GNtk/7dr918nl",
"https://s.blibli.com/GNtk/cc74cung",
"https://s.blibli.com/GNtk/1im51skr",
"https://s.blibli.com/GNtk/06qiasxq",
